{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tasks/contracts/blackboard/ideation-output.schema.json",
  "title": "Ideation Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "slug",
    "product_identity",
    "target_problem",
    "value_proposition",
    "key_user_journey",
    "constraints_out_of_scope",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9]{4}$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "product_identity": {
      "type": "string",
      "minLength": 1
    },
    "target_problem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "persona",
        "pain_point",
        "structural_limitations"
      ],
      "properties": {
        "persona": {
          "type": "string",
          "minLength": 1
        },
        "pain_point": {
          "type": "string",
          "minLength": 1
        },
        "structural_limitations": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "value_proposition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "customer_utility",
        "differentiated_advantage"
      ],
      "properties": {
        "customer_utility": {
          "type": "string",
          "minLength": 1
        },
        "differentiated_advantage": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "key_user_journey": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "constraints_out_of_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "constraints",
        "out_of_scope"
      ],
      "properties": {
        "constraints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "out_of_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
