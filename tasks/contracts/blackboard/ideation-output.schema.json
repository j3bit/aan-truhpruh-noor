{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tasks/contracts/blackboard/ideation-output.schema.json",
  "title": "Ideation Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "slug",
    "product_story",
    "problem_statement",
    "target_users",
    "goals",
    "non_goals",
    "constraints",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9]{4}$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "product_story": {
      "type": "string",
      "minLength": 1
    },
    "problem_statement": {
      "type": "string",
      "minLength": 1
    },
    "target_users": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "goals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "non_goals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
