{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tasks/contracts/blackboard/trd-output.schema.json",
  "title": "TRD Output",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "slug",
    "prd_path",
    "trd_path",
    "components",
    "interfaces",
    "dependency_rules",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9]{4}$"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "prd_path": {
      "type": "string",
      "pattern": "^tasks/prd-[0-9]{4}-[a-z0-9][a-z0-9-]*\\.md$"
    },
    "trd_path": {
      "type": "string",
      "pattern": "^tasks/trd-[0-9]{4}-[a-z0-9][a-z0-9-]*\\.md$"
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "interfaces": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "dependency_rules": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
